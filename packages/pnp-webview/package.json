{
  "name": "pnp-webview",
  "version": "0.0.1",
  "description": "React-based webview UI for Analog Attach VS Code extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "yarn build && vite",
    "build": "tsc --noEmit && vite build",
    "watch": "tsc --noEmit --watch && vite build --watch",
    "preview": "vite preview",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "allotment": "^1.20.5",
    "attach-ui-lib": "workspace:*",
    "classnames": "^2.5.1",
    "extension-protocol": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode-elements/webview-playground": "^1.9.0",
    "@vscode/codicons": "^0.0.36",
    "hds-react": "workspace:*",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
