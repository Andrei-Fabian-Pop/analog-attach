{
  "name": "attach-cli",
  "author": "AnalogDevices",
  "description": "CLI tool for configuring Linux device tree overlays",
  "license": "Apache-2.0",
  "type": "module",
  "version": "0.1.0",
  "files": [
    "dist",
    "scripts",
    "bundled",
    "SKILL.md"
  ],
  "bin": {
    "__attach_bash_complete": "dist/bash-complete.js",
    "attach": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "tsc -p src/tsconfig.json",
    "build": "tsup --silent --dts",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo node_modules",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage"
  },
  "tsup": {
    "entry": [
      "src/bin/cli.ts",
      "src/bin/bash-complete.ts"
    ],
    "format": [
      "esm"
    ],
    "tsconfig": "src/tsconfig.json",
    "clean": true,
    "splitting": true,
    "minify": true,
    "noExternal": [
      "attach-lib"
    ],
    "external": [
      "yaml"
    ]
  },
  "dependencies": {
    "@stricli/auto-complete": "^1.2.6",
    "@stricli/core": "^1.2.6",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "25.x",
    "@vitest/coverage-v8": "^4.0.18",
    "attach-lib": "*",
    "tsup": "^6.7.0",
    "typescript": "5.6.x",
    "vitest": "^4.0.18"
  }
}
