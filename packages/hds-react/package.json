{
  "name": "hds-react",
  "version": "0.0.1",
  "description": "React wrapper components for HDS Components",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/styles/index.css": "./dist/styles/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "watch": "vite build --watch",
    "clean": "rm -rf dist out"
  },
  "dependencies": {
    "@lit/react": "^1.0.5",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "hds-components": "workspace:*",
    "sass": "^1.93.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-dts": "^4.3.0"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
