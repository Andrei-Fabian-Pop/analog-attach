        {
            "key": "controller-data",
            "value": {
                "_t": "object",
                "properties": [
                    {
                        "key": "samsung,spi-feedback-delay",
                        "value": {
                            "_t": "enum_integer",
                            "enum": [
                                0,
                                1,
                                2,
                                3
                            ],
                            "typeSize": 32,
                            "description": "The sampling phase shift to be applied on the miso line (to account\nfor any lag in the miso line). Valid values:\n - 0: No phase shift.\n - 1: 90 degree phase shift sampling.\n - 2: 180 degree phase shift sampling.\n - 3: 270 degree phase shift sampling.\n",
                            "default": 0
                        }
                    }
                ]
            }
        },
        {
            "key": "nvidia,tx-clk-tap-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 31,
                "typeSize": 32,
                "description": "Delays the clock going out to device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device."
            }
        },
        {
            "key": "nvidia,rx-clk-tap-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 255,
                "typeSize": 32,
                "description": "Delays the clock coming in from the device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device."
            }
        }
    ],
    "pattern_properties": [
        {
            "pattern": "^channel@([0-9a-f])$",
            "description": "A few properties are defined in a common way ADC channels.",
            "properties": [
                {
                    "key": "reg",
                    "value": {
                        "_t": "integer",
                        "minimum": 0,
                        "maximum": 15,
                        "description": "The channel number."
                    }
                },
                {
                    "key": "diff-channels",
                    "value": {
                        "_t": "number_array",
                        "minItems": 2,
                        "maxItems": 2,
                        "minimum": 0,
                        "maximum": 29,
                        "typeSize": 32,
                        "description": "Besides the analog inputs available, internal inputs can be used.\n16: Internal temperature sensor.\n17: AVSS\n18: Internal reference\n19: DGND\n20: (AVDD − AVSS)/6+\n21: (AVDD − AVSS)/6-\n22: (IOVDD − DGND)/6+\n23: (IOVDD − DGND)/6-\n24: (ALDO − AVSS)/6+\n25: (ALDO − AVSS)/6-\n26: (DLDO − DGND)/6+\n27: (DLDO − DGND)/6-\n28: V_MV_P\n29: V_MV_M\n"
                    }
                },
                {
                    "key": "adi,reference-select",
                    "value": {
                        "_t": "enum_integer",
                        "enum": [
                            0,
                            1,
                            2,
                            3
                        ],
                        "typeSize": 32,
                        "description": "Select the reference source to use when converting on the\nspecific channel. Valid values are:\n0: REFIN1(+)/REFIN1(−)\n1: REFIN2(+)/REFIN2(−)\n2: REFOUT/AVSS (Internal reference)\n3: AVDD/AVSS\nIf not specified, REFIN1 is used.\n",
                        "default": 0
                    }
                },
                {
                    "key": "adi,excitation-pin-0",
                    "value": {
                        "_t": "integer",
                        "minimum": 0,
                        "maximum": 15,
                        "typeSize": 32,
                        "description": "Analog input to apply excitation current to while the channel\nis active.\n",
                        "default": 0
                    }
                },
                {
                    "key": "adi,excitation-pin-1",
                    "value": {
                        "_t": "integer",
                        "minimum": 0,
                        "maximum": 15,
                        "typeSize": 32,
                        "description": "Analog input to apply excitation current to while this channel\nis active.\n",
                        "default": 0
                    }
                },
                {
                    "key": "adi,excitation-current-0-nanoamp",
                    "value": {
                        "_t": "generic",
                        "description": "Excitation current in nanoamps to be applied to pin specified in\nadi,excitation-pin-0 while this channel is active.\n"
                    }
                },
                {
                    "key": "adi,excitation-current-1-nanoamp",
                    "value": {
                        "_t": "generic",
                        "description": "Excitation current in nanoamps to be applied to pin specified in\nadi,excitation-pin-1 while this channel is active.\n"
                    }
                },
                {
                    "key": "adi,burnout-current-nanoamp",
                    "value": {
                        "_t": "generic",
                        "description": "Burnout current in nanoamps to be applied for this channel.\n"
                    }
                },
                {
                    "key": "adi,buffered-positive",
                    "value": {
                        "_t": "boolean",
                        "description": "Enable buffered mode for positive input."
                    }
                },
                {
                    "key": "adi,buffered-negative",
                    "value": {
                        "_t": "boolean",
                        "description": "Enable buffered mode for negative input."
                    }
                }
            ],
            "required": [
                "reg",
                "diff-channels"
            ]
        }
    ],
    "examples": [
        "#include <dt-bindings/interrupt-controller/irq.h>\n\nspi {\n  #address-cells = <1>;\n  #size-cells = <0>;\n\n  adc@0 {\n    compatible = \"adi,ad4130\";\n    reg = <0>;\n\n    #address-cells = <1>;\n    #size-cells = <0>;\n\n    spi-max-frequency = <5000000>;\n    interrupts = <27 IRQ_TYPE_EDGE_FALLING>;\n    interrupt-parent = <&gpio>;\n\n    channel@0 {\n      reg = <0>;\n\n      adi,reference-select = <2>;\n\n      /* AIN8, AIN9 */\n      diff-channels = <8 9>;\n    };\n\n    channel@1 {\n      reg = <1>;\n\n      adi,reference-select = <2>;\n\n      /* AIN10, AIN11 */\n      diff-channels = <10 11>;\n    };\n\n    channel@2 {\n      reg = <2>;\n\n      adi,reference-select = <2>;\n\n      /* Temperature Sensor, DGND */\n      diff-channels = <16 19>;\n    };\n\n    channel@3 {\n      reg = <3>;\n\n      adi,reference-select = <2>;\n\n      /* Internal reference, DGND */\n      diff-channels = <18 19>;\n    };\n\n    channel@4 {\n      reg = <4>;\n\n      adi,reference-select = <2>;\n\n      /* DGND, DGND */\n      diff-channels = <19 19>;\n    };\n  };\n};\n"
    ]
}