{
    "$id": "http://devicetree.org/schemas/iio/dac/adi,ad3552r.yaml#",
    "title": "Analog Devices AD2552R DAC device driver",
    "description": "Bindings for the Analog Devices AD3552R DAC device and similar.\nDatasheet can be found here:\n  https://www.analog.com/media/en/technical-documentation/data-sheets/ad3541r.pdf\n  https://www.analog.com/media/en/technical-documentation/data-sheets/ad3542r.pdf\n  https://www.analog.com/media/en/technical-documentation/data-sheets/ad3551r.pdf\n  https://www.analog.com/media/en/technical-documentation/data-sheets/ad3552r.pdf\n",
    "properties": {
        "compatible": {
            "items": [
                {
                    "enum": [
                        "adi,ad3541r",
                        "adi,ad3542r",
                        "adi,ad3551r",
                        "adi,ad3552r"
                    ]
                }
            ],
            "type": "array",
            "minItems": 1,
            "maxItems": 1
        },
        "reg": {
            "minItems": 1,
            "maxItems": 1,
            "items": {
                "items": [
                    {
                        "minimum": 0,
                        "maximum": 256,
                        "type": "integer"
                    }
                ],
                "type": "array",
                "minItems": 1,
                "maxItems": 1
            },
            "description": "Chip select used by the device.",
            "type": "array"
        },
        "spi-max-frequency": {
            "description": "Maximum SPI clocking speed of the device in Hz.",
            "type": "integer",
            "typeSize": 32,
            "minimum": 0,
            "maximum": 66000000
        },
        "reset-gpios": {
            "maxItems": 1,
            "type": "array",
            "minItems": 1
        },
        "ldac-gpios": {
            "description": "LDAC pin to be used as a hardware trigger to update the DAC channels.\n",
            "maxItems": 1,
            "type": "array",
            "minItems": 1
        },
        "vref-supply": {
            "description": "The regulator to use as an external reference. If it does not exists the internal reference will be used. External reference must be 2.5V"
        },
        "adi,vref-out-en": {
            "description": "Vref I/O driven by internal vref to 2.5V. If not set, Vref pin will be floating.",
            "type": "boolean"
        },
        "adi,sdo-drive-strength": {
            "description": "Configure SDIO0 and SDIO1 strength levels:\n  - 0: low SDO drive strength.\n  - 1: medium low SDO drive strength.\n  - 2: medium high SDO drive strength.\n  - 3: high SDO drive strength\n",
            "enum": [
                0,
                1,
                2,
                3
            ],
            "type": "integer",
            "typeSize": 32,
            "minimum": 0,
            "maximum": 4294967295
        },
        "io-backends": {
            "description": "The iio backend reference. Device can be optionally connected to the \"axi-ad3552r IP\" fpga-based QSPI + DDR (Double Data Rate) controller to reach high speed transfers.",
            "maxItems": 1,
            "type": "array",
            "minItems": 1
        },
        "#address-cells": {
            "const": 1
        },
        "#size-cells": {
            "const": 0
        }
    },
    "patternProperties": {
        "^channel@([0-1])$": {
            "type": "object",
            "description": "Configurations of the DAC Channels",
            "additionalProperties": false,
            "properties": {
                "reg": {
                    "description": "Channel number",
                    "items": [
                        {
                            "items": [
                                {
                                    "enum": [
                                        0,
                                        1
                                    ]
                                }
                            ],
                            "type": "array",
                            "minItems": 1,
                            "maxItems": 1
                        }
                    ],
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1
                },
                "adi,output-range-microvolt": true,
                "custom-output-range-config": {
                    "type": "object",
                    "additionalProperties": false,
                    "description": "Configuration of custom range when adi,output-range-microvolt is not present. The formulas for calculation the output voltages are Vout_fs = 2.5 + [(GainN + Offset/1024) * 2.5 * Rfbx * 1.03] Vout_zs = 2.5 - [(GainP + Offset/1024) * 2.5 * Rfbx * 1.03]",
                    "properties": {
                        "adi,gain-offset": {
                            "description": "Gain offset used in the above formula",
                            "maximum": 511,
                            "minimum": -511,
                            "type": "integer"
                        },
                        "adi,gain-scaling-p": {
                            "description": "GainP = 1 / ( 2 ^ adi,gain-scaling-p)",
                            "enum": [
                                0,
                                1,
                                2,
                                3
                            ],
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "adi,gain-scaling-n": {
                            "description": "GainN = 1 / ( 2 ^ adi,gain-scaling-n)",
                            "enum": [
                                0,
                                1,
                                2,
                                3
                            ],
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "adi,rfb-ohms": {
                            "description": "Feedback Resistor"
                        }
                    },
                    "required": [
                        "adi,gain-offset",
                        "adi,gain-scaling-p",
                        "adi,gain-scaling-n",
                        "adi,rfb-ohms"
                    ]
                }
            },
            "required": [
                "reg"
            ],
            "oneOf": [
                {
                    "required": [
                        "adi,output-range-microvolt"
                    ]
                },
                {
                    "required": [
                        "custom-output-range-config"
                    ]
                }
            ]
        }
    },
    "allOf": [
        {
            "$id": "http://devicetree.org/schemas/spi/spi-peripheral-props.yaml#",
            "title": "Peripheral-specific properties for a SPI bus.",
            "description": "Many SPI controllers need to add properties to peripheral devices. They could be common properties like spi-max-frequency, spi-cpha, etc. or they could be controller specific like delay in clock or data lines, etc. These properties need to be defined in the peripheral node because they are per-peripheral and there can be multiple peripherals attached to a controller. All those properties are listed here. The controller specific properties should go in their own separate schema that should be referenced from here.",
            "properties": {
                "spi-cs-high": {
                    "description": "The device requires the chip select active high.",
                    "oneOf": [
                        {
                            "type": "boolean",
                            "const": true
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "spi-lsb-first": {
                    "description": "The device requires the LSB first mode.",
                    "oneOf": [
                        {
                            "type": "boolean",
                            "const": true
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "spi-cs-setup-delay-ns": {
                    "description": "Delay in nanoseconds to be introduced by the controller after CS is asserted."
                },
                "spi-cs-hold-delay-ns": {
                    "description": "Delay in nanoseconds to be introduced by the controller before CS is de-asserted."
                },
                "spi-cs-inactive-delay-ns": {
                    "description": "Delay in nanoseconds to be introduced by the controller after CS is de-asserted."
                },
                "spi-rx-bus-width": {
                    "description": "Bus width to the SPI bus used for read transfers. If 0 is provided, then no RX will be possible on this device.",
                    "enum": [
                        0,
                        1,
                        2,
                        4,
                        8
                    ],
                    "default": 1,
                    "type": "integer",
                    "typeSize": 32,
                    "minimum": 0,
                    "maximum": 4294967295
                },
                "spi-rx-delay-us": {
                    "description": "Delay, in microseconds, after a read transfer."
                },
                "rx-sample-delay-ns": {
                    "description": "SPI Rx sample delay offset, unit is nanoseconds. The delay from the default sample time before the actual sample of the rxd input signal occurs."
                },
                "spi-tx-bus-width": {
                    "description": "Bus width to the SPI bus used for write transfers. If 0 is provided, then no TX will be possible on this device.",
                    "enum": [
                        0,
                        1,
                        2,
                        4,
                        8
                    ],
                    "default": 1,
                    "type": "integer",
                    "typeSize": 32,
                    "minimum": 0,
                    "maximum": 4294967295
                },
                "spi-tx-delay-us": {
                    "description": "Delay, in microseconds, after a write transfer."
                },
                "stacked-memories": {
                    "description": "Several SPI memories can be wired in stacked mode. This basically means that either a device features several chip selects, or that different devices must be seen as a single bigger chip. This basically doubles (or more) the total address space with only a single additional wire, while still needing to repeat the commands when crossing a chip boundary. The size of each chip should be provided as members of the array.",
                    "minItems": 2,
                    "maxItems": 4,
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "typeSize": 64,
                        "minimum": 0,
                        "maximum": 18446744073709552000
                    }
                },
                "parallel-memories": {
                    "description": "Several SPI memories can be wired in parallel mode. The devices are physically on a different buses but will always act synchronously as each data word is spread across the different memories (eg. even bits are stored in one memory, odd bits in the other). This basically doubles the address space and the throughput while greatly complexifying the wiring because as many busses as devices must be wired. The size of each chip should be provided as members of the array.",
                    "minItems": 2,
                    "maxItems": 4,
                    "type": "array",
                    "items": {
                        "type": "integer",
                        "typeSize": 64,
                        "minimum": 0,
                        "maximum": 18446744073709552000
                    }
                },
                "st,spi-midi-ns": {
                    "description": "Only for STM32H7, (Master Inter-Data Idleness) minimum time\ndelay in nanoseconds inserted between two consecutive data frames.\n"
                }
            },
            "allOf": [
                {
                    "$id": "http://devicetree.org/schemas/spi/arm,pl022-peripheral-props.yaml#",
                    "title": "Peripheral-specific properties for Arm PL022 SPI controller",
                    "properties": {
                        "pl022,interface": {
                            "description": "SPI interface type",
                            "enum": [
                                0,
                                1,
                                2
                            ],
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "pl022,com-mode": {
                            "description": "Specifies the transfer mode",
                            "enum": [
                                0,
                                1,
                                2
                            ],
                            "default": 1,
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "pl022,rx-level-trig": {
                            "description": "Rx FIFO watermark level",
                            "minimum": 0,
                            "maximum": 4,
                            "type": "integer",
                            "typeSize": 32
                        },
                        "pl022,tx-level-trig": {
                            "description": "Tx FIFO watermark level",
                            "minimum": 0,
                            "maximum": 4,
                            "type": "integer",
                            "typeSize": 32
                        },
                        "pl022,ctrl-len": {
                            "description": "Microwire interface - Control length",
                            "minimum": 3,
                            "maximum": 31,
                            "type": "integer",
                            "typeSize": 32
                        },
                        "pl022,wait-state": {
                            "description": "Microwire interface - Wait state",
                            "enum": [
                                0,
                                1
                            ],
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "pl022,duplex": {
                            "description": "Microwire interface - Full/Half duplex",
                            "enum": [
                                0,
                                1
                            ],
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        }
                    },
                    "additionalProperties": true
                },
                {
                    "$id": "http://devicetree.org/schemas/spi/cdns,qspi-nor-peripheral-props.yaml#",
                    "title": "Peripheral-specific properties for the Cadence QSPI controller.",
                    "description": "See spi-peripheral-props.yaml for more info.",
                    "properties": {
                        "cdns,read-delay": {
                            "description": "Delay for read capture logic, in clock cycles.",
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "cdns,tshsl-ns": {
                            "description": "Delay in nanoseconds for the length that the master mode chip select outputs are de-asserted between transactions."
                        },
                        "cdns,tsd2d-ns": {
                            "description": "Delay in nanoseconds between one chip select being de-activated and the activation of another."
                        },
                        "cdns,tchsh-ns": {
                            "description": "Delay in nanoseconds between last bit of current transaction and deasserting the device chip select (qspi_n_ss_out)."
                        },
                        "cdns,tslch-ns": {
                            "description": "Delay in nanoseconds between setting qspi_n_ss_out low and first bit transfer."
                        }
                    },
                    "additionalProperties": true
                },
                {
                    "$id": "http://devicetree.org/schemas/spi/fsl,dspi-peripheral-props.yaml#",
                    "title": "Peripheral-specific properties for Freescale DSPI controller",
                    "description": "See spi-peripheral-props.yaml for more info.",
                    "properties": {
                        "fsl,spi-cs-sck-delay": {
                            "deprecated": true,
                            "description": "Delay in nanoseconds between activating chip select and the start of clock signal, at the start of a transfer.",
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        },
                        "fsl,spi-sck-cs-delay": {
                            "deprecated": true,
                            "description": "Delay in nanoseconds between stopping the clock signal and deactivating chip select, at the end of a transfer.",
                            "type": "integer",
                            "typeSize": 32,
                            "minimum": 0,
                            "maximum": 4294967295
                        }
                    },
                    "additionalProperties": true
                },
                {
                    "$id": "http://devicetree.org/schemas/spi/samsung,spi-peripheral-props.yaml#",
                    "title": "Peripheral-specific properties for Samsung S3C/S5P/Exynos SoC SPI controller",
                    "description": "See spi-peripheral-props.yaml for more info.",
                    "properties": {
                        "controller-data": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "samsung,spi-feedback-delay": {
                                    "description": "The sampling phase shift to be applied on the miso line (to account\nfor any lag in the miso line). Valid values:\n - 0: No phase shift.\n - 1: 90 degree phase shift sampling.\n - 2: 180 degree phase shift sampling.\n - 3: 270 degree phase shift sampling.\n",
                                    "enum": [
                                        0,
                                        1,
                                        2,
                                        3
                                    ],
                                    "default": 0,
                                    "type": "integer",
                                    "typeSize": 32,
                                    "minimum": 0,
                                    "maximum": 4294967295
                                }
                            }
                        }
                    },
                    "additionalProperties": true
                },
                {
                    "$id": "http://devicetree.org/schemas/spi/nvidia,tegra210-quad-peripheral-props.yaml#",
                    "title": "Peripheral properties for Tegra Quad SPI Controller",
                    "properties": {
                        "nvidia,tx-clk-tap-delay": {
                            "description": "Delays the clock going out to device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device.",
                            "minimum": 0,
                            "maximum": 31,
                            "type": "integer",
                            "typeSize": 32
                        },
                        "nvidia,rx-clk-tap-delay": {
                            "description": "Delays the clock coming in from the device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device.",
                            "minimum": 0,
                            "maximum": 255,
                            "type": "integer",
                            "typeSize": 32
                        }
                    },
                    "additionalProperties": true
                }
            ],
            "additionalProperties": true
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "enum": [
                                "adi,ad3541r",
                                "adi,ad3542r"
                            ]
                        },
                        "type": "array"
                    }
                },
                "required": [
                    "compatible"
                ],
                "type": "object"
            },
            "then": {
                "patternProperties": {
                    "^channel@([0-1])$": {
                        "type": "object",
                        "properties": {
                            "adi,output-range-microvolt": {
                                "description": "Voltage output range of the channel as <minimum, maximum>\nRequired connections:\n  Rfb1x for: 0 to 2.5 V; 0 to 3V; 0 to 5 V;\n  Rfb2x for: 0 to 10 V; -2.5 to 7.5V; -5 to 5 V;\n",
                                "oneOf": [
                                    {
                                        "items": [
                                            {
                                                "const": 0
                                            },
                                            {
                                                "enum": [
                                                    2500000,
                                                    3000000,
                                                    5000000,
                                                    10000000
                                                ]
                                            }
                                        ],
                                        "type": "array"
                                    },
                                    {
                                        "items": [
                                            {
                                                "const": -2500000
                                            },
                                            {
                                                "const": 7500000
                                            }
                                        ],
                                        "type": "array"
                                    },
                                    {
                                        "items": [
                                            {
                                                "const": -5000000
                                            },
                                            {
                                                "const": 5000000
                                            }
                                        ],
                                        "type": "array"
                                    }
                                ]
                            }
                        },
                        "required": [
                            "adi,output-range-microvolt"
                        ]
                    }
                },
                "properties": {
                    "__canary__": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "enum": [
                                "adi,ad3551r",
                                "adi,ad3552r"
                            ]
                        },
                        "type": "array"
                    }
                },
                "required": [
                    "compatible"
                ],
                "type": "object"
            },
            "then": {
                "patternProperties": {
                    "^channel@([0-1])$": {
                        "type": "object",
                        "properties": {
                            "adi,output-range-microvolt": {
                                "description": "Voltage output range of the channel as <minimum, maximum>\nRequired connections:\n  Rfb1x for: 0 to 2.5 V; 0 to 5 V;\n  Rfb2x for: 0 to 10 V; -5 to 5 V;\n  Rfb4x for: -10 to 10V\n",
                                "oneOf": [
                                    {
                                        "items": [
                                            {
                                                "const": 0
                                            },
                                            {
                                                "enum": [
                                                    2500000,
                                                    5000000,
                                                    10000000
                                                ]
                                            }
                                        ],
                                        "type": "array"
                                    },
                                    {
                                        "items": [
                                            {
                                                "const": -5000000
                                            },
                                            {
                                                "const": 5000000
                                            }
                                        ],
                                        "type": "array"
                                    },
                                    {
                                        "items": [
                                            {
                                                "const": -10000000
                                            },
                                            {
                                                "const": 10000000
                                            }
                                        ],
                                        "type": "array"
                                    }
                                ]
                            }
                        }
                    }
                },
                "properties": {
                    "__canary__": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "enum": [
                                "adi,ad3541r",
                                "adi,ad3551r"
                            ]
                        },
                        "type": "array"
                    }
                },
                "required": [
                    "compatible"
                ],
                "type": "object"
            },
            "then": {
                "properties": {
                    "channel@1": false,
                    "channel@0": {
                        "properties": {
                            "reg": {
                                "const": 0
                            }
                        }
                    },
                    "__canary__": false
                }
            }
        }
    ],
    "required": [
        "compatible",
        "reg",
        "spi-max-frequency"
    ],
    "additionalProperties": false,
    "examples": [
        "spi {\n    #address-cells = <1>;\n    #size-cells = <0>;\n    ad3552r@0 {\n        compatible = \"adi,ad3552r\";\n        reg = <0>;\n        spi-max-frequency = <20000000>;\n        #address-cells = <1>;\n        #size-cells = <0>;\n        channel@0 {\n            reg = <0>;\n            adi,output-range-microvolt = <0 10000000>;\n        };\n        channel@1 {\n            reg = <1>;\n            custom-output-range-config {\n                adi,gain-offset = <5>;\n                adi,gain-scaling-p = <1>;\n                adi,gain-scaling-n = <2>;\n                adi,rfb-ohms = <1>;\n            };\n        };\n    };\n};\n"
    ],
    "type": "object"
}