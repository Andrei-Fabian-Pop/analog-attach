{
    "required_properties": [
        "compatible",
        "reg"
    ],
    "properties": [
        {
            "key": "compatible",
            "value": {
                "_t": "enum_array",
                "minItems": 1,
                "maxItems": 1,
                "enum": [
                    "adi,ad2s90"
                ],
                "default": "adi,ad2s90",
                "enum_type": "string"
            }
        },
        {
            "key": "reg",
            "value": {
                "_t": "matrix",
                "minItems": 1,
                "maxItems": 1,
                "description": "Chip select used by the device.",
                "values": [
                    {
                        "_t": "number_array",
                        "minItems": 1,
                        "maxItems": 1,
                        "minimum": 0,
                        "maximum": 256
                    }
                ]
            }
        },
        {
            "key": "spi-max-frequency",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 830000,
                "typeSize": 32,
                "description": "Chip's max frequency, as specified in its datasheet, is 2Mhz. But a 600ns\ndelay is expected between the application of a logic LO to CS and the\napplication of SCLK, as also specified. And since the delay is not\nimplemented in the spi code, to satisfy it, SCLK's period should be at\nmost 2 * 600ns, so the max frequency should be 1 / (2 * 6e-7), which gives\nroughly 830000Hz.\n"
            }
        },
        {
            "key": "spi-cpol",
            "value": {
                "_t": "boolean"
            }
        },
        {
            "key": "spi-cpha",
            "value": {
                "_t": "boolean"
            }
        },
        {
            "key": "spi-cs-high",
            "value": {
                "_t": "boolean",
                "description": "The device requires the chip select active high."
            }
        },
        {
            "key": "spi-lsb-first",
            "value": {
                "_t": "boolean",
                "description": "The device requires the LSB first mode."
            }
        },
        {
            "key": "spi-cs-setup-delay-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds to be introduced by the controller after CS is asserted."
            }
        },
        {
            "key": "spi-cs-hold-delay-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds to be introduced by the controller before CS is de-asserted."
            }
        },
        {
            "key": "spi-cs-inactive-delay-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds to be introduced by the controller after CS is de-asserted."
            }
        },
        {
            "key": "spi-rx-bus-width",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1,
                    2,
                    4,
                    8
                ],
                "typeSize": 32,
                "description": "Bus width to the SPI bus used for read transfers. If 0 is provided, then no RX will be possible on this device.",
                "default": 1
            }
        },
        {
            "key": "spi-rx-delay-us",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay, in microseconds, after a read transfer."
            }
        },
        {
            "key": "rx-sample-delay-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "SPI Rx sample delay offset, unit is nanoseconds. The delay from the default sample time before the actual sample of the rxd input signal occurs."
            }
        },
        {
            "key": "spi-tx-bus-width",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1,
                    2,
                    4,
                    8
                ],
                "typeSize": 32,
                "description": "Bus width to the SPI bus used for write transfers. If 0 is provided, then no TX will be possible on this device.",
                "default": 1
            }
        },
        {
            "key": "spi-tx-delay-us",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay, in microseconds, after a write transfer."
            }
        },
        {
            "key": "stacked-memories",
            "value": {
                "_t": "number_array",
                "minItems": 2,
                "maxItems": 4,
                "minimum": 0,
                "maximum": 18446744073709552000,
                "typeSize": 64,
                "description": "Several SPI memories can be wired in stacked mode. This basically means that either a device features several chip selects, or that different devices must be seen as a single bigger chip. This basically doubles (or more) the total address space with only a single additional wire, while still needing to repeat the commands when crossing a chip boundary. The size of each chip should be provided as members of the array."
            }
        },
        {
            "key": "parallel-memories",
            "value": {
                "_t": "number_array",
                "minItems": 2,
                "maxItems": 4,
                "minimum": 0,
                "maximum": 18446744073709552000,
                "typeSize": 64,
                "description": "Several SPI memories can be wired in parallel mode. The devices are physically on a different buses but will always act synchronously as each data word is spread across the different memories (eg. even bits are stored in one memory, odd bits in the other). This basically doubles the address space and the throughput while greatly complexifying the wiring because as many busses as devices must be wired. The size of each chip should be provided as members of the array."
            }
        },
        {
            "key": "st,spi-midi-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Only for STM32H7, (Master Inter-Data Idleness) minimum time\ndelay in nanoseconds inserted between two consecutive data frames.\n"
            }
        },
        {
            "key": "pl022,interface",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1,
                    2
                ],
                "typeSize": 32,
                "description": "SPI interface type"
            }
        },
        {
            "key": "pl022,com-mode",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1,
                    2
                ],
                "typeSize": 32,
                "description": "Specifies the transfer mode",
                "default": 1
            }
        },
        {
            "key": "pl022,rx-level-trig",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 4,
                "typeSize": 32,
                "description": "Rx FIFO watermark level"
            }
        },
        {
            "key": "pl022,tx-level-trig",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 4,
                "typeSize": 32,
                "description": "Tx FIFO watermark level"
            }
        },
        {
            "key": "pl022,ctrl-len",
            "value": {
                "_t": "integer",
                "minimum": 3,
                "maximum": 31,
                "typeSize": 32,
                "description": "Microwire interface - Control length"
            }
        },
        {
            "key": "pl022,wait-state",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1
                ],
                "typeSize": 32,
                "description": "Microwire interface - Wait state"
            }
        },
        {
            "key": "pl022,duplex",
            "value": {
                "_t": "enum_integer",
                "enum": [
                    0,
                    1
                ],
                "typeSize": 32,
                "description": "Microwire interface - Full/Half duplex"
            }
        },
        {
            "key": "cdns,read-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 4294967295,
                "typeSize": 32,
                "description": "Delay for read capture logic, in clock cycles."
            }
        },
        {
            "key": "cdns,tshsl-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds for the length that the master mode chip select outputs are de-asserted between transactions."
            }
        },
        {
            "key": "cdns,tsd2d-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds between one chip select being de-activated and the activation of another."
            }
        },
        {
            "key": "cdns,tchsh-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds between last bit of current transaction and deasserting the device chip select (qspi_n_ss_out)."
            }
        },
        {
            "key": "cdns,tslch-ns",
            "value": {
                "_t": "number_array",
                "minItems": 1,
                "maxItems": 1,
                "minimum": "0",
                "maximum": "4294967295",
                "description": "Delay in nanoseconds between setting qspi_n_ss_out low and first bit transfer."
            }
        },
        {
            "key": "fsl,spi-cs-sck-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 4294967295,
                "typeSize": 32,
                "description": "Delay in nanoseconds between activating chip select and the start of clock signal, at the start of a transfer."
            }
        },
        {
            "key": "fsl,spi-sck-cs-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 4294967295,
                "typeSize": 32,
                "description": "Delay in nanoseconds between stopping the clock signal and deactivating chip select, at the end of a transfer."
            }
        },
        {
            "key": "controller-data",
            "value": {
                "_t": "object",
                "properties": [
                    {
                        "key": "samsung,spi-feedback-delay",
                        "value": {
                            "_t": "enum_integer",
                            "enum": [
                                0,
                                1,
                                2,
                                3
                            ],
                            "typeSize": 32,
                            "description": "The sampling phase shift to be applied on the miso line (to account\nfor any lag in the miso line). Valid values:\n - 0: No phase shift.\n - 1: 90 degree phase shift sampling.\n - 2: 180 degree phase shift sampling.\n - 3: 270 degree phase shift sampling.\n",
                            "default": 0
                        }
                    }
                ]
            }
        },
        {
            "key": "nvidia,tx-clk-tap-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 31,
                "typeSize": 32,
                "description": "Delays the clock going out to device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device."
            }
        },
        {
            "key": "nvidia,rx-clk-tap-delay",
            "value": {
                "_t": "integer",
                "minimum": 0,
                "maximum": 255,
                "typeSize": 32,
                "description": "Delays the clock coming in from the device with this tap value. Tap value varies based on platform design trace lengths from Tegra QSPI to corresponding slave device."
            }
        }
    ],
    "examples": [
        "spi {\n    #address-cells = <1>;\n    #size-cells = <0>;\n\n    resolver@0 {\n        compatible = \"adi,ad2s90\";\n        reg = <0>;\n        spi-max-frequency = <830000>;\n        spi-cpol;\n        spi-cpha;\n    };\n};\n"
    ]
}