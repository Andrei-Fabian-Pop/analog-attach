    "properties": [
        {
            "key": "compatible",
            "value": {
                "_t": "enum_array",
                "minItems": 1,
                "maxItems": 1,
                "enum": [
                    "st,stm32f4-adc-core",
                    "st,stm32h7-adc-core",
                    "st,stm32mp1-adc-core",
                    "st,stm32mp13-adc-core"
                ],
                "enum_type": "string"
            }
        },
        {
            "key": "reg",
            "value": {
                "_t": "matrix",
                "minItems": 1,
                "maxItems": 1,
                "values": [
                    {
                        "_t": "number_array",
                        "minItems": 1,
                        "maxItems": 1,
                        "minimum": "0",
                        "maximum": "4294967295"
                    }
                ]
            }
        },
        {
            "key": "interrupts",
            "value": {
                "_t": "matrix",
                "minItems": 1,
                "maxItems": 2,
                "values": [
                    {
                        "_t": "fixed_index",
                        "prefixItems": [
                            {
                                "_t": "number"
                            },
                            {
                                "_t": "number"
                            },
                            {
                                "_t": "enum",
                                "enum": [
                                    "IRQ_TYPE_NONE",
                                    "IRQ_TYPE_EDGE_RISING",
                                    "IRQ_TYPE_EDGE_FALLING",
                                    "IRQ_TYPE_EDGE_BOTH",
                                    "IRQ_TYPE_LEVEL_HIGH",
                                    "IRQ_TYPE_LEVEL_LOW"
                                ],
                                "enum_type": "macro"
                            }
                        ],
                        "minItems": 3,
                        "maxItems": 3
                    }
                ]
            }
        },
        {
            "key": "interrupt-parent",
            "value": {
                "_t": "enum_array",
                "minItems": 1,
                "maxItems": 1,
                "enum": [
                    "gpio",
                    "gicv2",
                    "aon_intr"
                ],
                "default": "gicv2",
                "enum_type": "phandle"
            }
        },
        {
            "key": "#interrupt-cells",
            "value": {
                "_t": "const",
                "const": 1
            }
        },
        {
            "key": "interrupt-controller",
            "value": {
                "_t": "boolean"
            }
        },
        {
            "key": "clocks",
            "value": {
                "_t": "matrix",
                "minItems": 1,
                "maxItems": 1,
                "values": [
                    {
                        "_t": "fixed_index",
                        "minItems": 1,
                        "maxItems": 1,
                        "prefixItems": [
                            {
                                "_t": "enum",
                                "enum": [
                                    "clk_osc",
                                    "clk_usb",
                                    "clk_27MHz",
                                    "clk_108MHz",
                                    "cam1_clk",
                                    "cam0_clk"
                                ],
                                "enum_type": "phandle"
                            }
                        ]
                    }
                ]
