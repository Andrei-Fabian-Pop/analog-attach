        },
        {
            "key": "vdd-supply",
            "value": {
                "_t": "enum_array",
                "minItems": 1,
                "maxItems": 1,
                "enum": [
                    "cam1_reg",
                    "cam0_regulator",
                    "cam_dummy_reg",
                    "sd_vcc_reg",
                    "vdd_3v3_reg",
                    "vdd_5v0_reg"
                ],
                "enum_type": "phandle"
            }
        },
        {
            "key": "st,syscfg",
            "value": {
                "_t": "matrix",
                "minItems": 1,
                "maxItems": 1,
                "description": "Phandle to system configuration controller. It can be used to control the analog circuitry on stm32mp1.",
                "values": [
                    {
                        "_t": "array",
                        "minItems": 1,
                        "maxItems": 1
                    }
                ]
            }
        },
        {
            "key": "access-controllers",
            "value": {
                "_t": "array",
                "minItems": 1,
                "maxItems": 2
            }
