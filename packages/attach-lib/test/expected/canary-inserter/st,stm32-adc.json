{
    "$id": "http://devicetree.org/schemas/iio/adc/st,stm32-adc.yaml#",
    "$schema": "http://devicetree.org/meta-schemas/core.yaml#",
    "title": "STMicroelectronics STM32 ADC",
    "description": "STM32 ADC is a successive approximation analog-to-digital converter.\nIt has several multiplexed input channels. Conversions can be performed\nin single, continuous, scan or discontinuous mode. Result of the ADC is\nstored in a left-aligned or right-aligned 32-bit data register.\nConversions can be launched in software or using hardware triggers.\n\nThe analog watchdog feature allows the application to detect if the input\nvoltage goes beyond the user-defined, higher or lower thresholds.\n\nEach STM32 ADC block can have up to 3 ADC instances.\n",
    "maintainers": [
        "Fabrice Gasnier <fabrice.gasnier@foss.st.com>"
    ],
    "properties": {
        "compatible": {
            "enum": [
                "st,stm32f4-adc-core",
                "st,stm32h7-adc-core",
                "st,stm32mp1-adc-core",
                "st,stm32mp13-adc-core"
            ]
        },
        "reg": {
            "maxItems": 1
        },
        "interrupts": {
            "description": "One or more interrupts for ADC block, depending on part used:\n  - stm32f4 and stm32h7 share a common ADC interrupt line.\n  - stm32mp1 has two separate interrupt lines, one for each ADC within\n    ADC block.\n  - stm32mp13 has an interrupt line per ADC block.\n",
            "minItems": 1,
            "maxItems": 2
        },
        "clocks": {
            "minItems": 1,
            "maxItems": 2,
            "description": "Core can use up to two clocks, depending on part used:\n  - \"adc\" clock: for the analog circuitry, common to all ADCs.\n    It's required on stm32f4.\n    It's optional on stm32h7 and stm32mp1.\n  - \"bus\" clock: for registers access, common to all ADCs.\n    It's not present on stm32f4.\n    It's required on stm32h7 and stm32mp1.\n"
        },
        "clock-names": {
            "minItems": 1,
            "maxItems": 2
        },
        "st,max-clk-rate-hz": {
            "description": "Allow to specify desired max clock rate used by analog circuitry."
        },
        "vdda-supply": {
            "description": "Phandle to the vdda input analog voltage."
        },
        "vref-supply": {
            "description": "Phandle to the vref input analog reference voltage."
        },
        "booster-supply": {
            "description": "Phandle to the embedded booster regulator that can be used to supply ADC analog input switches on stm32h7 and stm32mp1."
        },
        "vdd-supply": {
            "description": "Phandle to the vdd input voltage. It can be used to supply ADC analog input switches on stm32mp1."
        },
        "st,syscfg": {
            "description": "Phandle to system configuration controller. It can be used to control the analog circuitry on stm32mp1.",
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "array",
                "minItems": 1,
                "items": [
                    {
                        "oneOf": [
                            {
                                "type": "integer",
                                "minimum": 1,
                                "maximum": 4294967295
                            },
                            {
                                "type": "integer",
                                "const": 0
                            }
                        ]
                    }
                ],
                "additionalItems": {
                    "type": "integer",
                    "typeSize": 32,
                    "minimum": 0,
                    "maximum": 4294967295
                }
            }
        },
        "interrupt-controller": true,
        "#interrupt-cells": {
            "const": 1
        },
        "#address-cells": {
            "const": 1
        },
        "#size-cells": {
            "const": 0
        },
        "access-controllers": {
            "minItems": 1,
            "maxItems": 2
        }
    },
    "allOf": [
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "const": "st,stm32f4-adc-core"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "clocks": {
                        "maxItems": 1
                    },
                    "clock-names": {
                        "const": "adc"
                    },
                    "interrupts": {
                        "items": [
                            {
                                "description": "interrupt line common for all ADCs"
                            }
                        ]
                    },
                    "st,max-clk-rate-hz": {
                        "minimum": 600000,
                        "maximum": 36000000,
                        "default": 36000000
                    },
                    "booster-supply": false,
                    "vdd-supply": false,
                    "st,syscfg": false,
                    "__canary__": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "const": "st,stm32h7-adc-core"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "clocks": {
                        "minItems": 1,
                        "maxItems": 2
                    },
                    "clock-names": {
                        "items": [
                            {
                                "const": "bus"
                            },
                            {
                                "const": "adc"
                            }
                        ],
                        "minItems": 1
                    },
                    "interrupts": {
                        "items": [
                            {
                                "description": "interrupt line common for all ADCs"
                            }
                        ]
                    },
                    "st,max-clk-rate-hz": {
                        "minimum": 120000,
                        "maximum": 36000000,
                        "default": 36000000
                    },
                    "vdd-supply": false,
                    "st,syscfg": false,
                    "__canary__": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "const": "st,stm32mp1-adc-core"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "clocks": {
                        "minItems": 1,
                        "maxItems": 2
                    },
                    "clock-names": {
                        "items": [
                            {
                                "const": "bus"
                            },
                            {
                                "const": "adc"
                            }
                        ],
                        "minItems": 1
                    },
                    "interrupts": {
                        "items": [
                            {
                                "description": "interrupt line for ADC1"
                            },
                            {
                                "description": "interrupt line for ADC2"
                            }
                        ]
                    },
                    "st,max-clk-rate-hz": {
                        "minimum": 120000,
                        "maximum": 36000000,
                        "default": 36000000
                    },
                    "__canary__": false
                }
            }
        },
        {
            "if": {
                "properties": {
                    "compatible": {
                        "contains": {
                            "const": "st,stm32mp13-adc-core"
                        }
                    }
                }
            },
            "then": {
                "properties": {
                    "clocks": {
                        "minItems": 1,
                        "maxItems": 2
                    },
                    "clock-names": {
                        "items": [
                            {
                                "const": "bus"
                            },
                            {
                                "const": "adc"
                            }
                        ],
                        "minItems": 1
                    },
                    "interrupts": {
                        "items": [
                            {
                                "description": "ADC interrupt line"
                            }
                        ]
                    },
                    "st,max-clk-rate-hz": {
                        "minimum": 150000,
                        "maximum": 75000000,
                        "default": 75000000
                    },
                    "__canary__": false
                }
            }
        }
    ],
    "additionalProperties": false,
    "required": [
        "compatible",
        "reg",
        "interrupts",
        "clocks",
        "clock-names",
        "vdda-supply",
        "vref-supply",
        "interrupt-controller",
        "#interrupt-cells",
        "#address-cells",
        "#size-cells"
    ],
    "patternProperties": {
        "^adc@[0-9]+$": {
            "type": "object",
            "description": "An ADC block node should contain at least one subnode, representing an ADC instance available on the machine.",
            "properties": {
                "compatible": {
                    "enum": [
                        "st,stm32f4-adc",
                        "st,stm32h7-adc",
                        "st,stm32mp1-adc",
                        "st,stm32mp13-adc"
                    ]
                },
                "reg": {
                    "description": "Offset of ADC instance in ADC block. Valid values are:\n  - 0x0:   ADC1\n  - 0x100: ADC2\n  - 0x200: ADC3 (stm32f4 only)\n",
                    "maxItems": 1
                },
                "#io-channel-cells": {
                    "const": 1
                },
                "#address-cells": {
                    "const": 1
                },
                "#size-cells": {
                    "const": 0
                },
                "interrupts": {
                    "description": "IRQ Line for the ADC instance. Valid values are:\n  - 0 for adc@0 (single adc for stm32mp13)\n  - 1 for adc@100\n  - 2 for adc@200 (stm32f4 only)\n",
                    "maxItems": 1
                },
                "clocks": {
                    "description": "Input clock private to this ADC instance. It's required only on stm32f4, that has per instance clock input for registers access.",
                    "maxItems": 1
                },
                "dmas": {
                    "description": "RX DMA Channel",
                    "maxItems": 1
                },
                "dma-names": {
                    "const": "rx"
                },
                "assigned-resolution-bits": {
                    "description": "Resolution (bits) to use for conversions:\n  - can be 6, 8, 10 or 12 on stm32f4 and stm32mp13\n  - can be 8, 10, 12, 14 or 16 on stm32h7 and stm32mp1\n"
                },
                "st,adc-channels": {
                    "description": "List of single-ended channels muxed for this ADC. It can have up to:\n  - 16 channels, numbered from 0 to 15 (for in0..in15) on stm32f4\n  - 19 channels, numbered from 0 to 18 (for in0..in18) on stm32mp13.\n  - 20 channels, numbered from 0 to 19 (for in0..in19) on stm32h7 and\n    stm32mp1.\n",
                    "deprecated": true,
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "integer",
                        "typeSize": 32,
                        "minimum": 0,
                        "maximum": 4294967295
                    }
                },
                "st,adc-diff-channels": {
                    "description": "List of differential channels muxed for this ADC. Some channels can\nbe configured as differential instead of single-ended on stm32h7 and\non stm32mp1. Positive and negative inputs pairs are listed:\n<vinp vinn>, <vinp vinn>,... vinp and vinn are numbered from 0 to 19.\n\nNote: At least one of \"st,adc-channels\" or \"st,adc-diff-channels\" is\nrequired if no adc generic channel is defined. These legacy channel\nproperties are exclusive with adc generic channel bindings.\nBoth properties can be used together. Some channels can be\nused as single-ended and some other ones as differential (mixed). But\nchannels can't be configured both as single-ended and differential.\n",
                    "items": {
                        "items": [
                            {
                                "description": "\"vinp\" indicates positive input number\n",
                                "minimum": 0,
                                "maximum": 19
                            },
                            {
                                "description": "\"vinn\" indicates negative input number\n",
                                "minimum": 0,
                                "maximum": 19
                            }
                        ]
                    },
                    "deprecated": true,
                    "type": "array",
                    "minItems": 1
                },
                "st,min-sample-time-nsecs": {
                    "description": "Minimum sampling time in nanoseconds. Depending on hardware (board) e.g. high/low analog input source impedance, fine tune of ADC sampling time may be recommended. This can be either one value or an array that matches \"st,adc-channels\" and/or \"st,adc-diff-channels\" list, to set sample time resp. for all channels, or independently for each channel.",
                    "deprecated": true,
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "integer",
                        "typeSize": 32,
                        "minimum": 0,
                        "maximum": 4294967295
                    }
                },
                "nvmem-cells": {
                    "items": [
                        {
                            "description": "Phandle to the calibration vrefint data provided by otp"
                        }
                    ]
                },
                "nvmem-cell-names": {
                    "items": [
                        {
                            "const": "vrefint"
                        }
                    ]
                }
            },
            "patternProperties": {
                "^channel@([0-9]|1[0-9])$": {
                    "type": "object",
                    "description": "Represents the external channels which are connected to the ADC.",
                    "properties": {
                        "reg": {
                            "maxItems": 1,
                            "items": {
                                "minimum": 0,
                                "maximum": 19
                            }
                        },
                        "label": {
                            "description": "Unique name to identify which channel this is.\nReserved label names \"vddcore\", \"vddcpu\", \"vddq_ddr\", \"vrefint\" and \"vbat\"\nare used to identify internal channels with matching names.\n"
                        },
                        "diff-channels": {
                            "maxItems": 2,
                            "minItems": 1,
                            "description": "Many ADCs have dual Muxes to allow different input pins to be routed to both the positive and negative inputs of a differential ADC. The first value specifies the positive input pin, the second specifies the negative input pin. There are also some ADCs, where the differential channel has dedicated positive and negative inputs which can be used to measure differential voltage levels. For those setups, this property can be configured with the 'reg' property for both inputs (i.e. diff-channels = <reg reg>).",
                            "type": "array",
                            "items": {
                                "type": "integer",
                                "typeSize": 32,
                                "minimum": 0,
                                "maximum": 19
                            }
                        },
                        "st,min-sample-time-ns": {
                            "description": "Minimum sampling time in nanoseconds. Depending on hardware (board)\ne.g. high/low analog input source impedance, fine tune of ADC\nsampling time may be recommended.\n"
                        }
                    },
                    "required": [
                        "reg"
                    ],
                    "additionalProperties": false,
                    "$id": "http://devicetree.org/schemas/iio/adc/adc.yaml#",
                    "$schema": "http://devicetree.org/meta-schemas/core.yaml#",
                    "title": "IIO Common Properties for ADC Channels",
                    "maintainers": [
                        "Jonathan Cameron <jic23@kernel.org>"
                    ],
                    "anyOf": [
                        {
                            "oneOf": [
                                {
                                    "required": [
                                        "reg",
                                        "diff-channels"
                                    ]
                                },
                                {
                                    "required": [
                                        "reg",
                                        "single-channel"
                                    ]
                                }
                            ]
                        },
                        {
                            "required": [
                                "reg"
                            ]
                        }
                    ]
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "compatible": {
                                "contains": {
                                    "const": "st,stm32f4-adc"
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "reg": {
                                "enum": [
                                    0,
                                    256,
                                    512
                                ]
                            },
                            "interrupts": {
                                "minimum": 0,
                                "maximum": 2
                            },
                            "assigned-resolution-bits": {
                                "enum": [
                                    6,
                                    8,
                                    10,
                                    12
                                ],
                                "default": 12
                            },
                            "st,adc-channels": {
                                "minItems": 1,
                                "maxItems": 16,
                                "items": {
                                    "minimum": 0,
                                    "maximum": 15
                                }
                            },
                            "st,adc-diff-channels": false,
                            "st,min-sample-time-nsecs": {
                                "minItems": 1,
                                "maxItems": 16,
                                "items": {
                                    "minimum": 80
                                }
                            },
                            "__canary__": false
                        },
                        "required": [
                            "clocks"
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "compatible": {
                                "contains": {
                                    "enum": [
                                        "st,stm32h7-adc",
                                        "st,stm32mp1-adc"
                                    ]
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "reg": {
                                "enum": [
                                    0,
                                    256
                                ]
                            },
                            "interrupts": {
                                "minimum": 0,
                                "maximum": 1
                            },
                            "assigned-resolution-bits": {
                                "enum": [
                                    8,
                                    10,
                                    12,
                                    14,
                                    16
                                ],
                                "default": 16
                            },
                            "st,adc-channels": {
                                "minItems": 1,
                                "maxItems": 20,
                                "items": {
                                    "minimum": 0,
                                    "maximum": 19
                                }
                            },
                            "st,min-sample-time-nsecs": {
                                "minItems": 1,
                                "maxItems": 20,
                                "items": {
                                    "minimum": 40
                                }
                            },
                            "__canary__": false
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "compatible": {
                                "contains": {
                                    "const": "st,stm32mp13-adc"
                                }
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "reg": {
                                "const": 0
                            },
                            "interrupts": {
                                "const": 0
                            },
                            "assigned-resolution-bits": {
                                "enum": [
                                    6,
                                    8,
                                    10,
                                    12
                                ],
                                "default": 12
                            },
                            "st,adc-channels": {
                                "minItems": 1,
                                "maxItems": 19,
                                "items": {
                                    "minimum": 0,
                                    "maximum": 18
                                }
                            },
                            "st,min-sample-time-nsecs": {
                                "minItems": 1,
                                "maxItems": 19,
                                "items": {
                                    "minimum": 40
                                }
                            },
                            "__canary__": false
                        }
                    }
                }
            ],
            "additionalProperties": false,
            "required": [
                "compatible",
                "reg",
                "interrupts",
                "#io-channel-cells"
            ]
        }
    },
    "examples": [
        "// Example 1: with stm32f429, ADC1, single-ended channel 8\n  adc123: adc@40012000 {\n    compatible = \"st,stm32f4-adc-core\";\n    reg = <0x40012000 0x400>;\n    interrupts = <18>;\n    clocks = <&rcc 0 168>;\n    clock-names = \"adc\";\n    st,max-clk-rate-hz = <36000000>;\n    vdda-supply = <&vdda>;\n    vref-supply = <&vref>;\n    interrupt-controller;\n    #interrupt-cells = <1>;\n    #address-cells = <1>;\n    #size-cells = <0>;\n    adc@0 {\n      compatible = \"st,stm32f4-adc\";\n      #io-channel-cells = <1>;\n      reg = <0x0>;\n      clocks = <&rcc 0 168>;\n      interrupt-parent = <&adc123>;\n      interrupts = <0>;\n      st,adc-channels = <8>;\n      dmas = <&dma2 0 0 0x400 0x0>;\n      dma-names = \"rx\";\n      assigned-resolution-bits = <8>;\n    };\n    // ...\n    // other adc child nodes follow...\n  };\n",
        "// Example 2: with stm32mp157c to setup ADC1 with:\n// - channels 0 & 1 as single-ended\n// - channels 2 & 3 as differential (with resp. 6 & 7 negative inputs)\n  #include <dt-bindings/interrupt-controller/arm-gic.h>\n  #include <dt-bindings/clock/stm32mp1-clks.h>\n  adc12: adc@48003000 {\n    compatible = \"st,stm32mp1-adc-core\";\n    reg = <0x48003000 0x400>;\n    interrupts = <GIC_SPI 18 IRQ_TYPE_LEVEL_HIGH>,\n                 <GIC_SPI 90 IRQ_TYPE_LEVEL_HIGH>;\n    clocks = <&rcc ADC12>, <&rcc ADC12_K>;\n    clock-names = \"bus\", \"adc\";\n    booster-supply = <&booster>;\n    vdd-supply = <&vdd>;\n    vdda-supply = <&vdda>;\n    vref-supply = <&vref>;\n    st,syscfg = <&syscfg>;\n    interrupt-controller;\n    #interrupt-cells = <1>;\n    #address-cells = <1>;\n    #size-cells = <0>;\n    adc@0 {\n      compatible = \"st,stm32mp1-adc\";\n      #io-channel-cells = <1>;\n      reg = <0x0>;\n      interrupt-parent = <&adc12>;\n      interrupts = <0>;\n      st,adc-channels = <0 1>;\n      st,adc-diff-channels = <2 6>, <3 7>;\n      st,min-sample-time-nsecs = <5000>;\n      dmas = <&dmamux1 9 0x400 0x05>;\n      dma-names = \"rx\";\n    };\n    // ...\n    // other adc child node follow...\n  };\n",
        "// Example 3: with stm32mp157c to setup ADC2 with:\n// - internal channels 13, 14, 15.\n  #include <dt-bindings/interrupt-controller/arm-gic.h>\n  #include <dt-bindings/clock/stm32mp1-clks.h>\n  adc122: adc@48003000 {\n    compatible = \"st,stm32mp1-adc-core\";\n    reg = <0x48003000 0x400>;\n    interrupts = <GIC_SPI 18 IRQ_TYPE_LEVEL_HIGH>,\n                 <GIC_SPI 90 IRQ_TYPE_LEVEL_HIGH>;\n    clocks = <&rcc ADC12>, <&rcc ADC12_K>;\n    clock-names = \"bus\", \"adc\";\n    booster-supply = <&booster>;\n    vdd-supply = <&vdd>;\n    vdda-supply = <&vdda>;\n    vref-supply = <&vref>;\n    st,syscfg = <&syscfg>;\n    interrupt-controller;\n    #interrupt-cells = <1>;\n    #address-cells = <1>;\n    #size-cells = <0>;\n    adc@100 {\n      compatible = \"st,stm32mp1-adc\";\n      #io-channel-cells = <1>;\n      reg = <0x100>;\n      interrupts = <1>;\n      #address-cells = <1>;\n      #size-cells = <0>;\n      channel@13 {\n        reg = <13>;\n        label = \"vrefint\";\n        st,min-sample-time-ns = <9000>;\n      };\n      channel@14 {\n        reg = <14>;\n        label = \"vddcore\";\n        st,min-sample-time-ns = <9000>;\n      };\n      channel@15 {\n        reg = <15>;\n        label = \"vbat\";\n        st,min-sample-time-ns = <9000>;\n      };\n    };\n  };\n"
    ]
}